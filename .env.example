# ============================================================
# tenacious_bench — environment configuration
# Copy this file to .env and fill in your values.
# ============================================================

# ------------------------------------------------------------
# OpenRouter — required for run_evaluation.py
# https://openrouter.ai/keys
# ------------------------------------------------------------
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Default eval model (override via --model flag)
LLM_MODEL=openai/gpt-4.1-mini

# ------------------------------------------------------------
# HuggingFace — required for training scripts (optional for eval)
# https://huggingface.co/settings/tokens
# ------------------------------------------------------------
HF_TOKEN=your_hf_token_here

# ------------------------------------------------------------
# Langfuse — optional, for eval run tracing
# https://cloud.langfuse.com → Settings → API Keys
# ------------------------------------------------------------
LANGFUSE_PUBLIC_KEY=pk-lf-your_public_key_here
LANGFUSE_SECRET_KEY=sk-lf-your_secret_key_here
LANGFUSE_HOST=https://cloud.langfuse.com
